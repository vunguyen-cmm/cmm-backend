# Supabase (local dev: use local Supabase URL and anon key; testing DB = cmm_dev)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=your-local-anon-key
# Use for scripts that need to bypass RLS (e.g. import_schools_csv). Get from: supabase status
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_NAME=cmm_dev

# Airtable (for airtable_schema_to_postgres.py)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Optional: direct Postgres URL for applying generated schema (Supabase -> Database -> Connection string)
# DATABASE_URL=postgresql://postgres:password@host:54322/postgres

# AWS S3 (optional for local dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# App
SECRET_KEY=change-me-in-development
LOG_LEVEL=INFO
DEBUG=true
ENVIRONMENT=development
